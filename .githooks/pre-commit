#!/usr/bin/env bash
# Pre-commit hook: regenerate dev-blog/posts/posts.json from .md files
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SCRIPT="${ROOT_DIR}/dev-blog/scripts/generate-posts-json.mjs"

if [[ ! -f "${SCRIPT}" ]]; then
  echo "ERROR: dev-blog generator script not found: ${SCRIPT}" >&2
  exit 1
fi

node "${SCRIPT}"

# Stage the regenerated file so it is included in the commit
git -C "${ROOT_DIR}" add dev-blog/posts/posts.json
