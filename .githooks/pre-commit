#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SCRIPT="${ROOT_DIR}/scripts/uk_aq_inject_project_ref.mjs"
TARGETS=(
  "hex_map.html"
  "index.html"
  "sensors_chart.html"
  "sensors_map.html"
)

if [[ ! -f "${SCRIPT}" ]]; then
  echo "ERROR: injector script not found: ${SCRIPT}" >&2
  exit 1
fi

node "${SCRIPT}" "${TARGETS[@]}"
git -C "${ROOT_DIR}" add "${TARGETS[@]}"
